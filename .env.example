RESEND_API_KEY=
RESEND_FROM=
CONTACT_FORM_TO=

# Comma-separated origins allowed to call /api/* when the frontend is on a separate domain.
ALLOWED_ORIGINS=https://cosama.co,https://www.cosama.co,https://learn.cosama.co

# Leave blank when the same Coolify app serves the frontend and API.
# Set this to the API origin when the frontend is hosted separately, for example:
# VITE_API_BASE_URL=https://learn.cosama.co
VITE_API_BASE_URL=
